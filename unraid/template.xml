<?xml version="1.0"?>
<Container version="2">
  <Name>Eyeris</Name>
  <Repository>ghcr.io/vonhex/eyeris:latest</Repository>
  <Registry>https://github.com/vonhex/Eyeris/pkgs/container/eyeris</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/vonhex/Eyeris/issues</Support>
  <Project>https://github.com/vonhex/Eyeris</Project>
  <Overview>Self-hosted AI photo manager. Scans your NAS, generates thumbnails, detects faces, and tags images automatically.</Overview>
  <Category>MediaApp:Photos</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/vonhex/Eyeris/main/unraid/template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/vonhex/Eyeris/main/eyeris-logo-icon2.png</Icon>
  <ExtraParams>--group-add render --group-add video -v /sys:/sys:ro</ExtraParams>
  <Description>AI-Powered Photo Organizer. Your Pictures. Fast. Easy. Simple.</Description>

  <!-- ── Ports ── -->
  <Config Name="Web UI Port" Target="8000" Default="8000" Mode="tcp"
          Description="Port for the Eyeris web interface and API"
          Type="Port" Display="always" Required="true" Mask="false">8000</Config>

  <!-- ── Data paths ── -->
  <Config Name="Photo Directory" Target="/data/images" Default="/mnt/user/Pictures/"
          Description="Your photo library — local folder or SMB mount point"
          Type="Path" Display="always" Required="true" Mode="rw" Mask="false">/mnt/user/Pictures/</Config>

  <Config Name="Thumbnails" Target="/data/thumbnails" Default="/mnt/user/appdata/eyeris/thumbnails/"
          Description="Where Eyeris stores generated thumbnails and AI model cache"
          Type="Path" Display="always" Required="true" Mode="rw" Mask="false">/mnt/user/appdata/eyeris/thumbnails/</Config>

  <Config Name="Database" Target="/data/db" Default="/mnt/user/appdata/eyeris/db/"
          Description="SQLite database storage (ignored if DB_HOST is set)"
          Type="Path" Display="always" Required="true" Mode="rw" Mask="false">/mnt/user/appdata/eyeris/db/</Config>

  <Config Name="Config file (.env)" Target="/app/.env" Default="/mnt/user/appdata/eyeris/eyeris.env"
          Description="Persistent config file — Eyeris reads and writes auth secrets here. Create an empty file at this path on first run."
          Type="Path" Display="always" Required="true" Mode="rw" Mask="false">/mnt/user/appdata/eyeris/eyeris.env</Config>

  <!-- ── GPU device passthrough ── -->
  <Config Name="Intel / AMD GPU device" Target="/dev/dri" Default="/dev/dri"
          Description="Pass through Intel iGPU/Arc or AMD GPU for hardware acceleration. Remove if using NVIDIA only."
          Type="Device" Display="advanced" Required="false" Mask="false">/dev/dri</Config>

  <!-- ── NAS (SMB) ── -->
  <Config Name="NAS Host" Target="SMB_HOST" Default=""
          Description="IP or hostname of your NAS (leave empty if photos are in the Photo Directory path above)"
          Type="Variable" Display="always" Required="false" Mask="false"></Config>

  <Config Name="NAS Username" Target="SMB_USERNAME" Default=""
          Description="SMB username"
          Type="Variable" Display="always" Required="false" Mask="false"></Config>

  <Config Name="NAS Password" Target="SMB_PASSWORD" Default=""
          Description="SMB password"
          Type="Variable" Display="always" Required="false" Mask="true"></Config>

  <Config Name="NAS Shares" Target="SMB_SHARES" Default=""
          Description="Comma-separated share names to scan, e.g. photos,media"
          Type="Variable" Display="always" Required="false" Mask="false"></Config>

  <!-- ── Database (optional MariaDB — leave blank for SQLite) ── -->
  <Config Name="MariaDB Host" Target="DB_HOST" Default=""
          Description="MariaDB host IP — leave empty to use the built-in SQLite database (recommended)"
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="MariaDB Port" Target="DB_PORT" Default="3306"
          Description="MariaDB port"
          Type="Variable" Display="advanced" Required="false" Mask="false">3306</Config>

  <Config Name="MariaDB User" Target="DB_USER" Default="root"
          Description="MariaDB username"
          Type="Variable" Display="advanced" Required="false" Mask="false">root</Config>

  <Config Name="MariaDB Password" Target="DB_PASSWORD" Default=""
          Description="MariaDB password"
          Type="Variable" Display="advanced" Required="false" Mask="true"></Config>

  <Config Name="MariaDB Database" Target="DB_NAME" Default="image_catalog"
          Description="MariaDB database name"
          Type="Variable" Display="advanced" Required="false" Mask="false">image_catalog</Config>

  <!-- ── Scanner ── -->
  <Config Name="Scan Workers" Target="SCAN_CONCURRENCY" Default="2"
          Description="Parallel image processing workers (2–4 recommended; raise for fast CPUs)"
          Type="Variable" Display="always" Required="false" Mask="false">2</Config>

  <Config Name="Scan Interval (minutes)" Target="SCAN_INTERVAL_MINUTES" Default="60"
          Description="How often to rescan for new images"
          Type="Variable" Display="advanced" Required="false" Mask="false">60</Config>

  <!-- ── AI (optional) ── -->
  <Config Name="LLM Server URL" Target="LLAMA_CPP_URL" Default=""
          Description="URL of a running llama.cpp server for rich AI image descriptions (optional)"
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <Config Name="SearXNG URL" Target="SEARXNG_URL" Default=""
          Description="URL of a SearXNG instance for web image search (optional)"
          Type="Variable" Display="advanced" Required="false" Mask="false"></Config>

  <!-- ── NVIDIA GPU (handled separately by Unraid's GPU plugin) ── -->
  <GPU support="yes">
    <NVIDIA>true</NVIDIA>
  </GPU>
</Container>
