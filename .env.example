# ── NAS (SMB/CIFS) ────────────────────────────────────────────────────────────
# IP or hostname of your NAS. Leave SMB_HOST empty to scan local files instead.
SMB_HOST=                           # e.g. 192.168.1.100
SMB_USERNAME=
SMB_PASSWORD=
SMB_SHARES=photos                   # comma-separated share names, e.g. photos,media

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DB_HOST empty to use the built-in SQLite database (recommended for most users)
DB_HOST=                            # e.g. 192.168.1.100  (MariaDB/MySQL only)
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=image_catalog

# ── Scanner ───────────────────────────────────────────────────────────────────
SCAN_CONCURRENCY=2                  # parallel workers (raise for fast CPUs, max ~8)
SCAN_INTERVAL_MINUTES=60            # how often to rescan for new images

# ── Scheduled scan window (optional) ──────────────────────────────────────────
SCAN_SCHEDULE_ENABLED=false
SCAN_SCHEDULE_START=22:00           # only scan between these hours
SCAN_SCHEDULE_END=06:00

# ── AI / Vision (optional) ────────────────────────────────────────────────────
# Point to a running llama.cpp or compatible server for rich image descriptions
LLAMA_CPP_URL=                      # e.g. http://localhost:8081

# ── Web search (optional) ─────────────────────────────────────────────────────
SEARXNG_URL=                        # e.g. http://localhost:8887

# ── NSFW detection ────────────────────────────────────────────────────────────
# Comma-separated shares whose detected NSFW images are auto-moved to _detected_nsfw/
NSFW_FOLDERS=

# ── Authentication (auto-generated on first run, do not set manually) ─────────
# EYERIS_SECRET_KEY=
# EYERIS_PASSWORD_HASH=
